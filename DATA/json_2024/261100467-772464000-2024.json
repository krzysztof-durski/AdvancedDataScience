      "Beschwerdemanagement": {
        "Strukturiertes_Beschwerdemanagement": {
          "Strukturiertes_Beschwerdemanagement_Eingefuehrt": "ja",
          "Erlaeuterungen": "Jeder Patient und Besucher kann über Meinungsflyer Lob und Beschwerden an das Qualitätsmanagement richten. Ziel ist auf Probleme und geäußerte Anliegen persönlich einzugehen."
        },
        "Schriftliches_Konzept": {
          "Schriftliches_Konzept_Existiert": "ja",
          "Erlaeuterungen": "Das Beschwerdemanagement dient dem Informationsgewinn und der Ursachenanalyse für Unzufriedenheiten mit dem Ziel, eine Verbesserung der Servicequalität zu erreichen.  Die Erfassung und Auswertung der Daten sind die Basis für daraus resultierende konkrete Verbesserungsmaßnahmen. Fehler- und Unzufriedenheitsquellen sollen so erkannt und beseitigt werden."
        },
        "Umgang_muendliche_Beschwerden": {
          "Umgang_muendliche_Beschwerden_Geregelt": "ja",
          "Erlaeuterungen": "Mündliche Beschwerden können direkt an die Patientenfürsprecherin oder MitarbeiterInnen unseres Hauses gerichtet werden. Eine interne Regelung zum weiteren Umgang liegt vor."
        },
        "Umgang_schriftliche_Beschwerden": {
          "Umgang_schriftliche_Beschwerden_Geregelt": "ja",
          "Erlaeuterungen": "Schriftliche Beschwerden können über Meinungsflyer, Briefe, E-Mail und Internet an das Qualitätsmanagement gerichtet werden. Der Beschwerdeführer erhält, soweit gewünscht, eine Information über den internen Umgang mit den geäußerten Anliegen."
        },
        "Zeitziele_fuer_Rueckmeldung": {
          "Zeitziele_fuer_Rueckmeldung_Definiert": "ja",
          "Erlaeuterungen": "Ziel ist, die dargestellten Probleme durch ein Gespräch mit allen Beteiligten zeitnah zu lösen. Gleichzeitig besteht das definierte Ziel, dem Beschwerdeführer binnen 14 Tagen eine angemessene Rückmeldung zukommen zu lassen."
        },
