    "Medizinisch_Pflegerische_Leistungsangebote": {
      "MP_Leistungsangebot": [
        {
          "MP_Schluessel": "MP56",
          "Erlaeuterungen": "Nach Stabilisierung der Patienten Durchführung Medizinischer Belastungserprobungen (häuslich, betrieblich) zur Vorbereitung auf die Wiedereingliederung in das Erwerbsleben"
        },
        {
          "MP_Schluessel": "MP08",
          "Erlaeuterungen": "Informationen über Wiedereingliederungsmöglichkeiten in das Erwerbsleben, ggf. Kontaktaufnahme mit zuständigen Ämtern, Beratungsstellen, etc."
        },
        {
          "MP_Schluessel": "MP16",
          "Erlaeuterungen": "Spezielles Therapieangebot zur Verbesserung und Wahrnehmung grundlegender Fertigkeiten und Fähigkeiten, wie z. B. Konzentrationsfähigkeit, Kreativität, Belastbarkeit, Frustrationstoleranz, Handlungsplanung, Selbstständigkeit, Kreativität, etc.."
        },
        {
          "MP_Schluessel": "MP34",
          "Erlaeuterungen": "Psychotherapeutische Einzeltherapiegespräche, Gruppentherapien, Angehörigengespräche, störungsspezifische Therapien (DBT, IPT)"
        },
        {
          "MP_Schluessel": "MP59",
          "Erlaeuterungen": "Gruppentherapien zur Verbesserung der Gedächtnisleistung, logischem Denken, etc. durch kognitives Training und kognitive Spiele"
        },
        {
          "MP_Schluessel": "MP15",
          "Erlaeuterungen": "Planung bezüglich notwendiger, ambulanter Weiterbehandlungsmöglichkeiten, Erstellung eines individuellen Nachsorgeplans, Kontaktherstellung ggf. zu ambulanten sozialen Diensten, etc.."
        },
        {
          "MP_Schluessel": "MP11",
          "Erlaeuterungen": "Spezielle Maßnahmen zur Bewegungsförderung, Verbesserung der Körperwahrnehmung und Vermittlung von Freude an körperlicher Bewegung, Integration von Bewegung und Sport in den Alltag, Verbesserung der körperlichen Fitness, etc."
        },
        {
          "MP_Schluessel": "MP52",
          "Erlaeuterungen": "Kooperation und Kontaktaufnahme mit Beratungsstellen, z. B. Suchtberatungsstelle, Caritas"
        },
        {
          "MP_Schluessel": "MP40",
          "Erlaeuterungen": "Gruppentherapieangebote, z. B. Progressive Muskelentsprannung nach Jakobsen, Yoga"
        },
        {
          "MP_Schluessel": "MP14",
          "Erlaeuterungen": "Ernährungsberatung im Einzelkontakt und in der Kleingruppe bezüglich gesunder und regionaler Ernährung, Allergien, Übergewicht, Fehlernährung, etc.."
        },
        {
          "MP_Schluessel": "MP17",
          "Erlaeuterungen": "Bezugspflegesystem, individuelle kontinuierliche Begleitung"
        },
        {
          "MP_Schluessel": "MP63",
          "Erlaeuterungen": "Individuelle Begleitung durch Anamneseerhebung, Klärung des Unterstützungsbedarfs, Kontaktaufnahme zu ambulanten Diensten, auch ggf. mit Arbeitgebern, Ämtern, IFD, etc.."
        }
      ]
    },
